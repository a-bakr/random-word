# Faseeh — copy to .env.local and fill in. Never commit real secrets.

# Supabase (browser-safe auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Supabase (server-side)
SUPABASE_SECRET_KEY=
SUPABASE_DB_URL=        # Postgres connection (prod: Supavisor pooler, port 6543, ?pgbouncer=true)

# Admin dashboard — email granted access (falls back to owner email if unset)
NEXT_PUBLIC_ADMIN_EMAIL=

# Bearer token for the daily aggregate cron
CRON_SECRET=

# Paymob subscriptions (from dashboard; Test-mode values until live)
# Authorization: Token <key> for the Intention API
PAYMOB_SECRET_KEY=
# pk_... for the Unified Checkout URL
PAYMOB_PUBLIC_KEY=
# verifies transaction callbacks
PAYMOB_HMAC_SECRET=
# comma-separated: card,wallet,kiosk
PAYMOB_INTEGRATION_IDS=

# Audio generation scripts only (not app runtime)
GEMINI_API_KEY=
# GEMINI_API_KEYS=key1,key2    # comma-separated, for key rotation
