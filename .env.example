# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
# Direct (dev) or Supavisor transaction pooler (prod, port 6543, ?pgbouncer=true) connection string.
SUPABASE_DB_URL=

# --- Admin dashboard ---
# Access is granted to whoever signs in (Supabase Auth / Google) with this email.
# Defaults to the owner if unset.
NEXT_PUBLIC_ADMIN_EMAIL=

# --- Cron ---
CRON_SECRET=

# --- Paymob (subscriptions) ---
# From the Paymob dashboard (use Test-mode values until going live).
PAYMOB_SECRET_KEY=          # secret/API key sent as `Authorization: Token <key>` to the Intention API
PAYMOB_PUBLIC_KEY=          # public key (pk_...) used in the Unified Checkout URL
PAYMOB_HMAC_SECRET=         # HMAC secret for verifying transaction callbacks
PAYMOB_INTEGRATION_IDS=     # comma-separated integration IDs (card, wallet, kiosk), e.g. 12345,12346,12347

# --- Audio generation scripts only (not app runtime) ---
GEMINI_API_KEY=
# GEMINI_API_KEYS=key1,key2
