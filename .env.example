#############################################
#                  FASEEH                    #
#       Environment variable reference        #
#                                            #
#  Copy to `.env.local` and fill in values.  #
#  Never commit real secrets (.env* is       #
#  gitignored except this file).             #
#############################################


# ─────────────────────────────────────────────
#  Supabase — Postgres + Auth
# ─────────────────────────────────────────────

# Client-side auth (browser-safe).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-side secret/service key (admin-role checks).
SUPABASE_SECRET_KEY=

# Postgres connection string for raw-SQL analytics queries.
#   • dev  → direct connection
#   • prod → Supavisor transaction pooler (port 6543, ?pgbouncer=true)
SUPABASE_DB_URL=


# ─────────────────────────────────────────────
#  Admin dashboard
# ─────────────────────────────────────────────

# Email granted admin access (via Supabase Auth / Google sign-in).
# Falls back to the owner email if unset.
NEXT_PUBLIC_ADMIN_EMAIL=


# ─────────────────────────────────────────────
#  Cron
# ─────────────────────────────────────────────

# Bearer token guarding the daily aggregate job.
CRON_SECRET=


# ─────────────────────────────────────────────
#  Paymob — subscriptions
# ─────────────────────────────────────────────
# From the Paymob dashboard (use Test-mode values until going live).

PAYMOB_SECRET_KEY=          # API key sent as `Authorization: Token <key>` to the Intention API
PAYMOB_PUBLIC_KEY=          # public key (pk_...) used in the Unified Checkout URL
PAYMOB_HMAC_SECRET=         # HMAC secret for verifying transaction callbacks
PAYMOB_INTEGRATION_IDS=     # comma-separated integration IDs (card, wallet, kiosk), e.g. 12345,12346,12347


# ─────────────────────────────────────────────
#  Audio generation scripts — not app runtime
# ─────────────────────────────────────────────

GEMINI_API_KEY=
# GEMINI_API_KEYS=key1,key2   # comma-separated, for key rotation
